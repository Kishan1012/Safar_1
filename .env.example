# =============================================================
# ROMY — Environment Variables Example
# Copy this file to .env and fill in your actual values
# =============================================================

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://romy_user:password@localhost:5432/romy_db
REDIS_URL=redis://localhost:6379

# ─── Auth (Supabase) ────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
JWT_SECRET=your-very-long-jwt-secret-here

# ─── Google APIs ────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...
GOOGLE_PLACES_API_KEY=AIza...
GOOGLE_VISION_API_KEY=AIza...
GOOGLE_ROUTES_API_KEY=AIza...
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# ─── Mapbox ─────────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=pk.eyJ1...
MAPBOX_SECRET_TOKEN=sk.eyJ1...

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ─── Social Media APIs ──────────────────────────────────────
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# ─── AWS ────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-secret
S3_BUCKET_NAME=romy-media-prod
CLOUDFRONT_DOMAIN=https://cdn.romy.travel

# ─── Stripe & RevenueCat ────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...
REVENUECAT_API_KEY=your-revenuecat-key

# ─── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=hello@romy.travel

# ─── Push Notifications (Firebase) ─────────────────────────
FIREBASE_PROJECT_ID=romy-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@romy-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Analytics ──────────────────────────────────────────────
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=https://...@sentry.io/...

# ─── App Config ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
WEB_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001,http://localhost:19006
